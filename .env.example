# 服务监听端口
PORT=3000

# 你的图片生成服务 Key。部署时只放在服务器环境变量里，不要写进前端代码。
OPENAI_API_KEY=sk-your-key

# 如果你的服务提供的是完整图片生成 URL，就填这个。
# OpenAI 官方默认值是：https://api.openai.com/v1/images/generations
OPENAI_IMAGE_URL=https://api.openai.com/v1/images/generations

# 如果只提供 base url，也可以不填 OPENAI_IMAGE_URL，改用：
# OPENAI_BASE_URL=https://api.openai.com/v1

# 按你的服务实际模型名填写；如果你的服务要求 gpt-image2，就改成 gpt-image2。
OPENAI_IMAGE_MODEL=gpt-image-2

# 图片接口最长等待时间，单位毫秒。默认 600000。
IMAGE_REQUEST_TIMEOUT_MS=600000

# 服务端给 nginx/browser 的心跳间隔，单位毫秒。默认 15000。
RESPONSE_HEARTBEAT_MS=15000

# 同时真正调用上游生图接口的数量。建议按上游额度调整，默认 6。
MAX_IMAGE_CONCURRENCY=6

# 等待执行的最大排队数量。100 人左右使用建议 80-150，默认 120。
MAX_IMAGE_QUEUE=120

# 请求在队列中等待的最长时间，单位毫秒。默认 180000。
QUEUE_TIMEOUT_MS=180000

# 单个 IP 的固定窗口限流。默认 1 分钟最多 4 次生图。
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=4

# 上游 JSON 响应体最大字节数，防止 base64 大图导致内存峰值过高。默认 64MB。
OPENAI_RESPONSE_MAX_BYTES=67108864

# 登录会话签名密钥。生产环境务必设置为强随机字符串，重启后保持不变。
SESSION_SECRET=replace-with-a-long-random-secret

# 用户数据文件。单机部署时请把 data/ 目录放在持久化磁盘上。
AUTH_DATA_FILE=./data/auth.json

# 每个用户的生图额度。默认 1 小时 6 次。
USER_IMAGE_LIMIT=6
USER_IMAGE_WINDOW_MS=3600000
